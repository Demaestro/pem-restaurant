ADMIN_PASSWORD=change-this-to-your-own-secure-password
FRONTEND_URL=http://localhost:5173
FRONTEND_URLS=
STORAGE_MODE=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
PAYSTACK_SECRET_KEY=

# Session + cookie hardening
SESSION_TTL_HOURS=168
COOKIE_DOMAIN=
COOKIE_SECURE=auto

# Transactional email (Resend.com — leave empty to log emails to the console in dev)
RESEND_API_KEY=
MAIL_FROM_ADDRESS=PEM <noreply@pem.local>
MAIL_BRAND_NAME=Precious Events Makers

# Optional: rate limit overrides (per IP, per window)
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_MS=900000
ORDER_RATE_LIMIT_MAX=30
ORDER_RATE_LIMIT_WINDOW_MS=900000
